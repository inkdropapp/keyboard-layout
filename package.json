{
  "name": "inkdrop-keyboard-layout",
  "version": "2.0.22",
  "description": "Read and observe the current keyboard layout on OS X.",
  "main": "./lib/keyboard-layout",
  "scripts": {
    "install": "pkg-prebuilds-verify binding-options.js || node-gyp rebuild",
    "prebuild": "node-gyp rebuild && pkg-prebuilds-copy --baseDir build/Release --source keyboard-layout-manager.node --name keyboard-layout-manager --strip --napi_version 8",
    "rebuild": "node-gyp rebuild",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inkdropapp/keyboard-layout.git"
  },
  "bugs": {
    "url": "https://github.com/inkdropapp/keyboard-layout/issues"
  },
  "licenses": [
    {
      "type": "MIT",
      "url": "http://github.com/inkdropapp/keyboard-layout/raw/master/LICENSE.md"
    }
  ],
  "dependencies": {
    "event-kit": "^2.5.3",
    "node-addon-api": "^8.8.0",
    "pkg-prebuilds": "^1.0.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "node-gyp": "^12.4.0"
  }
}
